# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Environment variables
.env
.env.*
!.env.example

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# OS/editor files
.DS_Store
.vscode/
.idea/

# Application runtime data
app.log
*.log
data/uploads/*
!data/uploads/.gitkeep
data/enrolled/*
!data/enrolled/.gitkeep
data/documents/*
!data/documents/.gitkeep

# YOLO model weights (large binary, download at runtime)
*.pt
*.pth

# Temp probe/reference images written during proctoring
data/uploads/probe_ws_*
data/uploads/docprobe_*
data/uploads/ref_*
